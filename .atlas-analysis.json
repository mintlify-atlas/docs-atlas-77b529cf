  "keyFeatures": [
    "Multi-agent orchestration via JSON-RPC supervisor",
    "Claude Code and Codex CLI runtime support",
    "Three agent lifecycle modes: 24/7, on-demand, idle_cached",
    "Per-agent worktree and $HOME isolation",
    "Async message bus with steer/follow-up priorities",
    "Structured state: tasks, initiatives, artifacts, hypotheses, capsules",
    "Shared skills system auto-discovered by agents",
    "Cron scheduling and external event ingestion",
    "Optional db9 brain adapter for cross-run memory",
    "Standalone CLI binary with scriptable JSON-RPC interface"
  ],
  "publicApiSurface": [
    "wanman takeover <path>",
    "wanman run <goal>",
    "wanman send <agent> <msg>",
    "wanman recv [--agent <name>]",
    "wanman agents",
    "wanman watch",
    "wanman task create|list|get|update|done",
    "wanman artifact put|list|get",
    "wanman initiative create|list|get|update",
    "wanman capsule create|list|mine|get|update",
    "wanman hypothesis create|list|update",
    "wanman context get|set",
    "wanman escalate <msg>",
    "wanman skill:check [path]",
    "createWanmanHostSdk()",
    "createEnvBackedWanmanHostSdk()",
    "WanmanHostSdk.run()",
    "WanmanHostSdk.takeover()",
    "WanmanHostSdk.prepareTakeover()",
    "WanmanHostSdk.executePreparedTakeover()"
  ]
}
